{
  "dashboard": {
    "id": null,
    "title": "JARVIS \u2014 Dashboard Executivo Wagner",
    "tags": [
      "jarvis",
      "executivo"
    ],
    "timezone": "America/Sao_Paulo",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Status Agentes JARVIS",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 4
        },
        "targets": [
          {
            "expr": "up{job=~\"jarvis.*\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "OFFLINE"
                  },
                  "1": {
                    "text": "ONLINE"
                  }
                },
                "type": "value"
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Containers Docker",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(container_last_seen)",
            "legendFormat": "containers"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        }
      },
      {
        "id": 3,
        "title": "RAM JARVIS",
        "type": "gauge",
        "gridPos": {
          "x": 6,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100",
            "legendFormat": "RAM livre %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 20
                },
                {
                  "color": "green",
                  "value": 40
                }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Uptime Sistema",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "node_time_seconds - node_boot_time_seconds",
            "legendFormat": "uptime"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 5,
        "title": "Vetores Knowledge Base",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "jarvis_kb_vectors_total",
            "legendFormat": "vetores"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 6,
        "title": "Alertas Ultimas 24h",
        "type": "logs",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "{job=\"jarvis-alerts\"}",
            "legendFormat": ""
          }
        ]
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "schemaVersion": 38
  },
  "overwrite": true,
  "folderId": 0
}