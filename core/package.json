    "pg": "^8.11.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.2"
  }
}
