    "build": "npx tsc src/server.ts src/dispatcher.ts src/logger.ts src/agents/devops.ts --outDir dist --module commonjs --esModuleInterop true --skipLibCheck true --useUnknownInCatchVariables false",
    "start": "node dist/server.js"
  },
  "dependencies": {
