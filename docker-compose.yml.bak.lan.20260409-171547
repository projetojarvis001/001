services:
  postgres:
    image: postgres:16-alpine
    restart: always
    environment:
      POSTGRES_DB: jarvis_db
      POSTGRES_USER: jarvis_admin
      POSTGRES_PASSWORD: ${PG_PASSWORD}
    volumes:
      - pg_data:/var/lib/postgresql/data
    ports: 
      - '127.0.0.1:5432:5432'
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U jarvis_admin -d jarvis_db']
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: redis
    restart: always
    command: redis-server --requirepass ${REDIS_PASSWORD}
    ports: 
      - '127.0.0.1:6379:6379'
    volumes:
      - redis_data:/data

  jarvis-core:
    build: ./core
    container_name: jarvis-jarvis-core-1
    restart: always
    ports:
      - "127.0.0.1:3000:3000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    volumes:
      - /Users/jarvis001/jarvis:/host_jarvis
      - /Users/jarvis001/.ssh:/root/.ssh:ro
    environment:
      - DATABASE_URL=postgres://jarvis_admin:W%21%40%23wps%402026@postgres:5432/jarvis
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
      - VISION_HOST=${VISION_HOST}
      - GROQ_API_KEY=${GROQ_API_KEY}
      - GOOGLE_AI_KEY=${GOOGLE_AI_KEY}
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
      - TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID}

  grafana:
    image: grafana/grafana:latest
    restart: always
    volumes:
      - grafana_data:/var/lib/grafana
    ports: 
      - '127.0.0.1:3001:3000'
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GF_ADMIN_PASSWORD}

  n8n:
    image: n8nio/n8n
    restart: always
    ports:
      - "127.0.0.1:5678:5678"
    volumes:
      - n8n_data:/home/node/.n8n
    environment:
      - N8N_SECURE_COOKIE=false
      - WEBHOOK_URL=https://arranged-plus-threshold-campus.trycloudflare.com

volumes:
  pg_data:
  redis_data:
  n8n_data:
  grafana_data:
